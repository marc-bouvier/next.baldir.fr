{
  "useMarkdownLinks": true,
  "newLinkFormat": "absolute",
  "newFileLocation": "folder",
  "newFileFolderPath": "notes",
  "showUnsupportedFiles": true,
  "attachmentFolderPath": "public/img",
  "userIgnoreFilters": [
    "_site/",
    "node_modules/",
    "public/css/",
    "_includes/",
    "package.json",
    "package-lock.json",
    "public/css/",
    "_data/",
    "_includes/"
  ],
  "tabSize": 3,
  "alwaysUpdateLinks": true,
  "pdfExportSettings": {
    "pageSize": "Letter",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  },
  "promptDelete": false,
  "mobileToolbarCommands": [
    "editor:attach-file",
    "editor:insert-wikilink",
    "editor:set-heading",
    "command-palette:open",
    "editor:undo",
    "editor:insert-link",
    "editor:toggle-checklist-status",
    "note-composer:extract-heading",
    "editor:indent-list",
    "editor:unindent-list",
    "editor:redo"
  ]
}